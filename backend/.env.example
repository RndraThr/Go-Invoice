# KSM Invoice Out - Environment Variables
# Copy this file to .env and edit the values

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ksm_invoice

# Server
SERVER_PORT=8081

# JWT Secret (get this from Cost Control API admin)
# If empty, auth will fallback to calling Cost Control API /api/auth/me
JWT_SECRET=

# Cost Control API URL (for auth fallback & master data)
COST_CONTROL_API_URL=http://localhost:8080
